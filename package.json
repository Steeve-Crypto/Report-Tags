{
  "name": "git-sound-report",
  "displayName": "Git Sound Report",
  "description": "Plays celebratory 'report tag' sound effects on successful git production commands (add, commit, push to GitHub). Gamified dev experience!",
  "version": "0.1.0",
  "publisher": "athena-devtools",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitSoundReport.playTestSound",
        "title": "Git Sound Report: Play Test Sound"
      }
    ]
  },
  "scripts": {
    "package": "vsce package"
  },
  "keywords": ["git", "sound", "celebration", "productivity", "gamification"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/git-sound-report"
  }
}
